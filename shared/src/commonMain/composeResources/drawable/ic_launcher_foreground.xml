<?xml version="1.0" encoding="utf-8"?>
<!--
  Isometric hexagon cube logo for AltCoins.
  Viewport: 108x108, safe zone: 18-90 (72dp).
  Flat-top hexagon, r=33, center (54,54).
  Vertices:
    v0(87,54)  v1(70.5,25.4)  v2(37.5,25.4)
    v3(21,54)  v4(37.5,82.6)  v5(70.5,82.6)
  3 faces divided by lines from center to v0, v2, v4.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Top face (lightest): v1->v2->center->v0 -->
    <path
        android:fillColor="#F0F0F0"
        android:pathData="M 70.5,25.4 L 37.5,25.4 L 54,54 L 87,54 Z" />

    <!-- Left face (silver): v2->v3->v4->center -->
    <path
        android:fillColor="#7A7A7A"
        android:pathData="M 37.5,25.4 L 21,54 L 37.5,82.6 L 54,54 Z" />

    <!-- Bottom-right face (dark): v4->v5->v0->center -->
    <path
        android:fillColor="#2A2A2A"
        android:pathData="M 37.5,82.6 L 70.5,82.6 L 87,54 L 54,54 Z" />

    <!-- Outer hexagon outline (silver) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#888888"
        android:strokeWidth="0.8"
        android:pathData="M 87,54 L 70.5,25.4 L 37.5,25.4 L 21,54 L 37.5,82.6 L 70.5,82.6 Z" />

    <!-- Inner divider lines -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#666666"
        android:strokeWidth="0.6"
        android:pathData="M 54,54 L 87,54 M 54,54 L 37.5,25.4 M 54,54 L 37.5,82.6" />

</vector>
